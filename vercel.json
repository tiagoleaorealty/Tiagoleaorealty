{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python3 build.py",
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/blog/el-chante-tamarindo-villas/",
      "destination": "/blog-el-chante-tamarindo.html",
      "permanent": true
    },
    {
      "source": "/blog-post.html",
      "has": [
        {
          "type": "query",
          "key": "slug",
          "value": "el-chante-tamarindo-villas"
        }
      ],
      "destination": "/blog-el-chante-tamarindo.html",
      "permanent": true
    },
    {
      "source": "/property-detail.html",
      "has": [
        {
          "type": "query",
          "key": "id",
          "value": "(?<id>.+)"
        }
      ],
      "destination": "/property/:id/",
      "permanent": true
    },
    {
      "source": "/blog-post.html",
      "has": [
        {
          "type": "query",
          "key": "slug",
          "value": "(?<slug>.+)"
        }
      ],
      "destination": "/blog/:slug/",
      "permanent": true
    },
    {
      "source": "/school.html",
      "has": [
        {
          "type": "query",
          "key": "slug",
          "value": "(?<slug>.+)"
        }
      ],
      "destination": "/school/:slug/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/property/(.*)",
      "destination": "/property-detail.html"
    },
    {
      "source": "/school/(.*)",
      "destination": "/school.html"
    },
    {
      "source": "/blog/(.*)",
      "destination": "/blog-post.html"
    },
    {
      "source": "/development/(.*)",
      "destination": "/development.html"
    }
  ]
}