# Secrets — never commit these.
# The repo is public: anything committed here is readable by anyone, and bots
# scan public repos for keys within minutes of a push.
.env
.env.*
!.env.example
*.key
secrets.json

# Build artifacts — build.py regenerates these on every Vercel deploy.
# They are output, not source; committing them would just go stale.
/property/
/school/
/blog/

# macOS
.DS_Store
**/.DS_Store

# Editor
.vscode/
.idea/
*.swp
